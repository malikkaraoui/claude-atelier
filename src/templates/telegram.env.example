# ============================================================
# Telegram Bridge — Variables d'environnement
# Copier en .env et remplir les valeurs obligatoires
# ============================================================

# --- Obligatoires ---
TELEGRAM_BOT_TOKEN=         # Token depuis @BotFather
TELEGRAM_CHAT_ID=           # Ton ID (obtenir via t.me/userinfobot)
ALLOWED_USERS=              # Ton Telegram user_id (whitelist, virgule-séparés si plusieurs)
APPROVED_DIRECTORY=         # Répertoire projet par défaut (ex: /Users/moi/projects/mon-app)

# --- Claude CLI ---
CLAUDE_MAX_TURNS=20
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_COST_USD=50.0

# --- Transcription vocale (Phase B — local via faster-whisper) ---
WHISPER_MODEL=tiny          # tiny (rapide) ou base (meilleur, ~2x plus lent)
WHISPER_LANGUAGE=fr         # ou 'auto' pour détection automatique

# --- Ollama polish (Phase B — local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_POLISH_MODEL=qwen2.5:3b
OLLAMA_POLISH_TIMEOUT=10    # secondes, fallback=texte brut si dépassé
OLLAMA_POLISH_ENABLED=true  # false = skip polish, texte brut direct

# --- Sécurité & Rate limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600      # secondes (1 heure)

# --- Vault Peter ---
VAULT_INBOX=vault/.peter/inbox/telegram
VAULT_WRITE_ENABLED=true    # false = désactive l'écriture inbox
