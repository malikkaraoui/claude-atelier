# ============================================================
# Telegram Bridge — Variables d'environnement
# Copier en .env et remplir les valeurs obligatoires
# ============================================================

# --- Obligatoires ---
TELEGRAM_BOT_TOKEN=         # Token depuis @BotFather
TELEGRAM_CHAT_ID=           # Ton ID (obtenir via t.me/userinfobot)
ALLOWED_USERS=              # Ton Telegram user_id (whitelist, virgule-séparés si plusieurs)
APPROVED_DIRECTORY=         # Répertoire projet par défaut (ex: /Users/moi/projects/mon-app)

# --- Claude CLI ---
CLAUDE_MAX_TURNS=20
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_COST_USD=50.0

# --- Transcription vocale (Phase B — local via faster-whisper) ---
WHISPER_MODEL=tiny          # tiny (rapide) ou base (meilleur, ~2x plus lent)
WHISPER_LANGUAGE=fr         # ou 'auto' pour détection automatique

# --- Ollama chat (Phase A — bidirectionnel local, remplace claude CLI) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:latest  # modèle pour répondre aux messages Telegram (laisser vide = claude CLI)

# --- Ollama polish (Phase B — transcription vocale) ---
OLLAMA_POLISH_MODEL=qwen2.5:3b
OLLAMA_POLISH_TIMEOUT=10    # secondes, fallback=texte brut si dépassé
OLLAMA_POLISH_ENABLED=true  # false = skip polish, texte brut direct

# --- Sécurité & Rate limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600      # secondes (1 heure)

# --- OpenRouter — routing automatique (prioritaire sur Ollama + claude CLI si défini) ---
# Obtenir une clé : https://openrouter.ai/keys
OPENROUTER_API_KEY=         # laisser vide pour utiliser Ollama ou claude CLI
# "openrouter/auto" = OpenRouter choisit le modèle selon la complexité de la requête
OPENROUTER_DEFAULT_MODEL=openrouter/auto
# Modèles spécifiques par agent (JSON) — surcharge le modèle par défaut
# Agents disponibles : peter, serena, maestro, default (et tout autre agent claude-atelier)
# Exemple : {"peter":"anthropic/claude-sonnet-4-6","serena":"openai/gpt-4o","default":"openrouter/auto"}
OPENROUTER_AGENT_MODELS={}

# --- Vault Peter ---
VAULT_INBOX=vault/.peter/inbox/telegram
VAULT_MAILBOX=vault/10-mailbox.md   # mailbox Peter — remontée au SessionStart Claude
VAULT_WRITE_ENABLED=true    # false = désactive l'écriture inbox + mailbox
